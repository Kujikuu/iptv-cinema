<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Vertical gradient: solid black at the bottom to blend with content list -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#1A050505"
                android:centerColor="#A6050505"
                android:endColor="#FF050505"
                android:type="linear" />
        </shape>
    </item>
    <!-- Horizontal gradient: darker on the right to make spotlight text pop in RTL -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:startColor="#CC050505"
                android:endColor="#00050505"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
