<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chrome_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="true">

    <!-- Top bar: logo left, search centered, settings right -->
    <FrameLayout
        android:id="@+id/chrome_top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/chrome_top_bar_height"
        android:background="@drawable/chrome_top_bar_bg"
        android:paddingHorizontal="@dimen/row_padding_horizontal">

        <TextView
            android:id="@+id/chrome_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.TvIptv.ChromeLogo" />

        <TextView
            android:id="@+id/chrome_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/chrome_search_chip"
            android:drawableStart="@drawable/ic_search"
            android:drawableTint="@color/on_surface_secondary"
            android:drawablePadding="10dp"
            android:ellipsize="end"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:minWidth="@dimen/chrome_search_min_width"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:text="@string/search_hint"
            android:textAppearance="@style/TextAppearance.TvIptv.ChromeSearch" />

        <ImageButton
            android:id="@+id/chrome_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:background="@drawable/chrome_icon_button"
            android:contentDescription="@string/settings_title"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_settings"
            app:tint="@color/on_surface" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/chrome_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/row_padding_horizontal"
        android:layout_marginBottom="28dp"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/chrome_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.TvIptv.ChromeClock"
            tools:text="1:37 AM" />

        <TextView
            android:id="@+id/chrome_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.TvIptv.ChromeDate"
            tools:text="Monday, Jun 22" />
    </LinearLayout>
</FrameLayout>
