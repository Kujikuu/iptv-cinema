<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/launcher_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:focusable="false"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/launcher_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingTop="@dimen/launcher_content_top_padding">

        <androidx.leanback.widget.HorizontalGridView
            android:id="@+id/launcher_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:nextFocusDown="@id/continue_watching_grid" />

        <LinearLayout
            android:id="@+id/continue_watching_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/launcher_cw_section_top_margin"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="@dimen/launcher_cw_section_bottom_padding"
            android:visibility="gone">

            <TextView
                android:id="@+id/continue_watching_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:paddingHorizontal="@dimen/launcher_content_horizontal_padding"
                android:paddingBottom="@dimen/launcher_cw_header_bottom_padding"
                android:text="@string/continue_watching_row"
                android:textAppearance="@style/TextAppearance.TvIptv.RowHeader" />

            <androidx.leanback.widget.HorizontalGridView
                android:id="@+id/continue_watching_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:nextFocusUp="@id/launcher_grid" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
