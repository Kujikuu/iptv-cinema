<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingHorizontal="@dimen/row_padding_horizontal"
    android:paddingTop="96dp"
    android:paddingBottom="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsTitle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/settings_source_header"
            android:textAppearance="@style/TextAppearance.TvIptv.RowHeaderSubtitle" />

        <TextView
            android:id="@+id/settings_active_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="false"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem"
            tools:text="Active: My IPTV" />

        <TextView
            android:id="@+id/settings_last_refresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:focusable="false"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem"
            tools:text="Last refreshed: 2 days ago" />

        <TextView
            android:id="@+id/settings_refresh_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_refresh_interval"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem"
            tools:text="Auto-refresh: Every 2 days" />

        <TextView
            android:id="@+id/settings_refresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_refresh"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem" />

        <TextView
            android:id="@+id/settings_switch_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_switch_source"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem"
            tools:text="Switch source" />

        <TextView
            android:id="@+id/settings_delete_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_delete_source"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem" />

        <TextView
            android:id="@+id/settings_add_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_add_source"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/settings_library_header"
            android:textAppearance="@style/TextAppearance.TvIptv.RowHeaderSubtitle" />

        <TextView
            android:id="@+id/settings_continue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_continue_watching"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem" />

        <TextView
            android:id="@+id/settings_favorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_favorites"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem" />

        <TextView
            android:id="@+id/settings_clear_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_clear_history"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/settings_playback_header"
            android:textAppearance="@style/TextAppearance.TvIptv.RowHeaderSubtitle" />

        <TextView
            android:id="@+id/settings_autoplay_next_episode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_item_bg"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:text="@string/settings_autoplay_next_episode_on"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/settings_about_header"
            android:textAppearance="@style/TextAppearance.TvIptv.RowHeaderSubtitle" />

        <TextView
            android:id="@+id/settings_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:textAppearance="@style/TextAppearance.TvIptv.SettingsItem"
            tools:text="Version 1.0.0" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
