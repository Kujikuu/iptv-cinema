<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/row_padding_horizontal"
        android:paddingVertical="48dp">

        <androidx.cardview.widget.CardView
            android:layout_width="320dp"
            android:layout_height="180dp"
            app:cardBackgroundColor="@color/surface_elevated"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/details_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                tools:src="@drawable/card_placeholder" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/details_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="@style/TextAppearance.TvIptv.DetailsTitle"
                tools:text="Bein Max 1 AR 240P" />

            <TextView
                android:id="@+id/details_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/TextAppearance.TvIptv.DetailsSubtitle"
                tools:text="Sports · LIVE" />

            <TextView
                android:id="@+id/details_plot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:ellipsize="end"
                android:maxLines="4"
                android:textAppearance="@style/TextAppearance.TvIptv.DetailsBody"
                android:visibility="gone"
                tools:text="Channel description goes here."
                tools:visibility="visible" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/details_watch_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/details_action_primary"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center"
                    android:minWidth="220dp"
                    android:nextFocusRight="@id/details_favorite_button"
                    android:paddingHorizontal="28dp"
                    android:paddingVertical="14dp"
                    android:text="@string/watch_live"
                    android:textAppearance="@style/TextAppearance.TvIptv.DetailsActionPrimary"
                    tools:text="Watch Live" />

                <TextView
                    android:id="@+id/details_favorite_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/details_action_secondary"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center"
                    android:minWidth="220dp"
                    android:nextFocusLeft="@id/details_watch_button"
                    android:paddingHorizontal="28dp"
                    android:paddingVertical="14dp"
                    android:text="@string/add_favorite"
                    android:textAppearance="@style/TextAppearance.TvIptv.DetailsActionSecondary"
                    tools:text="Add to Favorites" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
